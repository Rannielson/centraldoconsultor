# Banco de Dados
DATABASE_URL=postgresql://postgres:rNUGuYJ1JHLr7gyp@db.tyyqrygkpoibslqegvow.supabase.co:5432/postgres

# Servidor
PORT=3000
NODE_ENV=development

# API Key Master (para criar outras keys)
MASTER_API_KEY=sua-chave-master-aqui

# API Key usada nas URLs curtas /app/s/:code (injeta no HTML, não expõe na URL).
# Em produção (ex.: Railway) defina com uma chave válida da tabela api_keys (pode ser a mesma que MASTER_API_KEY).
WEBAPP_API_KEY=sua-api-key-ou-mesma-de-cima

# URL base do app (para montar short link e link completo) — no Railway use a URL do serviço
APP_BASE_URL=https://centralconsultor.atomos.tech

# Logo por cliente (SaaS): cadastre logo_url na tabela clientes (ex.: URL do storage Proseg)

# Período exibido nos links /app/s/:code (formato DD/MM/YYYY). Opcional.
# BOLETOS_SHORT_DATA_INICIAL=20/02/2026
# BOLETOS_SHORT_DATA_FINAL=31/03/2026

# Sincronização diária às 9h10 — timezone do cron (opcional, default: America/Sao_Paulo)
# CRON_TIMEZONE=America/Sao_Paulo

# OpenPDF — geração de relatórios PDF por consultor (job diário)
OPENPDF_URL=http://openpdf.atomos.tech/v1/pdfs/render
OPENPDF_API_KEY=sk_live_xxx

# Cleoia WhatsApp — envio do link do PDF por consultor (job diário)
# No Railway: cole a URL SEM aspas. Ex: https://wabaapiq.cleoia.com.br/v3/bot/xxx/sendurl
CLEOIA_BOT_SEND_URL=https://wabaapiq.cleoia.com.br/v3/bot/SEU_BOT_ID/sendurl

# Relatório consolidado às 19h — destino do WhatsApp (opcional, default: 5581992387425)
# RELATORIO_CONSOLIDADO_DESTINO=5581992387425

# Relatório de produção (ranking) às 18h30 — destinos WhatsApp separados por vírgula (default: 5583996336133,5583988473502)
# RELATORIO_PRODUCAO_DESTINO=5583996336133,5583988473502

# Envio individual do relatório de produção para cada consultor (default: true). Use false ou 0 para desativar.
# RELATORIO_PRODUCAO_INDIVIDUAL=true

# Delay entre envios individuais em ms (default: 3000)
# RELATORIO_PRODUCAO_DELAY_MS=3000
